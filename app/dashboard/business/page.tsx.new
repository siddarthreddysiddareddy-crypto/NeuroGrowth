      </div>

      {/* AI Agent & Insights */}
      <div className="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-8">
        {/* AI Advisor */}
        <div className="lg:col-span-2 h-96">
          <ChatBox
            title="🤖 Business AI Advisor"
